# ==============================================================
# .envrc.example — plantilla. Copia a .envrc.local y rellena.
# .envrc.local NUNCA se commitea (está en .gitignore).
# ==============================================================

# --- Identidad git para este proyecto -------------------------
# (NO toca tu ~/.gitconfig global)
export GIT_AUTHOR_NAME="Tu Nombre"
export GIT_AUTHOR_EMAIL="correodeconsultoria@gmail.com"
export GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
export GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"

# --- GitHub CLI aislado ---------------------------------------
# Crea un Personal Access Token en https://github.com/settings/tokens
# Scopes recomendados: repo, workflow, read:org
export GH_CONFIG_DIR="$PWD/.gh-config"
export GH_TOKEN=""   # ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# --- gcloud aislado -------------------------------------------
# Toda la config y credenciales viven en ./.gcloud/, no en ~/.config/gcloud
export CLOUDSDK_CONFIG="$PWD/.gcloud"
export CLOUDSDK_ACTIVE_CONFIG_NAME="consciousness-class"
export GOOGLE_APPLICATION_CREDENTIALS="$PWD/.gcloud/sa-key.json"

# Project ID en GCP (ajusta al tuyo)
export GCLOUD_PROJECT="consciousness-class-prod"

# --- Firebase Admin (lectura por scripts/seed-db.ts) ----------
# Estos vienen de tu .env.local existente; no los dupliques aquí
# si ya están allí. Solo si quieres tener una segunda copia disponible
# en shells donde no se carga .env.local automáticamente.

# --- AI / Gemini ----------------------------------------------
# export GOOGLE_GENAI_API_KEY=""
